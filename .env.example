# ── MODUS ─────────────────────────────────────────────────────────────────────
# 'cli' = Claude Code CLI (kein API Key nötig, Claude Code muss installiert sein)
# 'api' = Anthropic API   (ANTHROPIC_API_KEY erforderlich)
CLAUDE_MODE=cli

# ── API (nur für CLAUDE_MODE=api) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3000

# ── AUTONOMER BETRIEB ─────────────────────────────────────────────────────────
CYCLE_INTERVAL_MINUTES=60
MAX_AGENT_CALLS_PER_CYCLE=20

# ── TOKEN-BUDGET (nur für CLAUDE_MODE=api) ────────────────────────────────────
DAILY_TOKEN_LIMIT=100000

# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# Meta-Evaluation nach jeder Deliberation (true/false)
META_EVALUATION=true

# Maximale Runden im iterativen Loop (default: 3)
MAX_LOOP_ROUNDS=3

# ── TELEGRAM NOTIFICATIONS ────────────────────────────────────────────────────
# Push-Benachrichtigungen bei kritischen Events (Eskalation, Metrik, Webhook)
# Leer lassen wenn keine Notifications gewünscht
# Setup: 1) @BotFather → /newbot → Token kopieren
#         2) @userinfobot → deine Chat-ID kopieren
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
