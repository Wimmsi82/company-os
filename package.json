{
  "name": "@wimmsi82/company-os",
  "version": "8.0.0",
  "description": "Autonomous multi-agent company OS — 8 specialist agents + CEO deliberate every business question in 3 phases. Runs 24/7 on Raspberry Pi.",
  "main": "src/index.js",
  "bin": {
    "company-os": "./run.js"
  },
  "scripts": {
    "setup":   "node setup.js",
    "start":   "node src/index.js",
    "dev":     "nodemon src/index.js",
    "migrate": "node src/db/migrate.js",
    "test":    "node --test tests/"
  },
  "files": [
    "src/",
    "run.js",
    "setup.js",
    ".env.example",
    "docs/",
    "company-os.service",
    "INSTALL.md",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "install-pi.sh",
    "install-mac.sh",
    "install-windows.ps1"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3":    "^9.4.3",
    "express":           "^4.18.3",
    "node-cron":         "^3.0.3",
    "dotenv":            "^16.4.5",
    "uuid":              "^9.0.1",
    "puppeteer":         "^22.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["ai", "agents", "llm", "deliberation", "company-os", "autonomous", "multi-agent"],
  "author": "Bernhard Wimmer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wimmsi82/company-os.git"
  },
  "homepage": "https://github.com/Wimmsi82/company-os#readme"
}
